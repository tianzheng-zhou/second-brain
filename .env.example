# Required
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional overrides
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PB_STORAGE_PATH=~/personal_brain_data
# PB_DB_PATH=~/personal_brain_data/brain.db

# Aliyun (required for PDF parsing via MinerU and audio transcription)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=

# MinerU PDF parser (optional, falls back to local OCR without it)
MINERU_API_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_USE_SYSTEM_PROXY=true

# Set to false to skip delete confirmations
DELETE_CONFIRMATION=true
